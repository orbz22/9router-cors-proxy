# Copy to .env and adjust as needed. All values optional (defaults shown).

# Address this proxy listens on (keep 127.0.0.1 — local only).
LISTEN_HOST=127.0.0.1
LISTEN_PORT=20129

# 9router gateway to forward to.
UPSTREAM_HOST=127.0.0.1
UPSTREAM_PORT=20128

# Comma-separated browser origins allowed to use credentialed CORS.
# Use "*" to allow any origin (disables credentials).
ALLOWED_ORIGINS=https://pivot.claude.ai,https://claude.ai

# Upstream response timeout in milliseconds.
UPSTREAM_TIMEOUT_MS=120000

# Logging: error | warn | info | debug
LOG_LEVEL=info

# Optional log file path (appends). Leave empty for stdout only.
# LOG_FILE=C:\Local Disk (D)\.Project\codes\9router-cors-proxy\proxy.log
